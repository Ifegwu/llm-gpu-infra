# Ansible connection
MI300X_PUBLIC_IP=""
MI300X_SSH_USER="root"

MODEL_ID="Qwen/Qwen3.6-27B"
VLLM_IMAGE="rocm/vllm-dev:nightly_main_20260211"
CONTAINER_NAME="vllm-mi300x"
HOST_PORT="8000"
TP_SIZE="1"
HF_HOME="/opt/llm/hf-cache"
WORKDIR_HOST="/opt/llm"
WORKDIR_CONTAINER="/workspace"

# ROCm / vLLM tuning for MI300X
VLLM_ROCM_USE_AITER="1"
VLLM_USE_AITER_UNIFIED_ATTENTION="1"
VLLM_ROCM_USE_AITER_MHA="0"

# Optional: set if model pulls require authentication
HUGGING_FACE_HUB_TOKEN=""
